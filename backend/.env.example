# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/metermate

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
JWT_SECRET=replace_with_a_secure_jwt_secret

# Interswitch
INTERSWITCH_CLIENT_ID=your_client_id
INTERSWITCH_CLIENT_SECRET=your_client_secret
INTERSWITCH_PASSPORT_URL=https://qa.interswitchng.com/passport/oauth/token
INTERSWITCH_QUICKTELLER_API=https://qa.interswitchng.com/quicktellerservice/api/v5
INTERSWITCH_COLLECTIONS_API=https://qa.interswitchng.com/collections/api/v1
INTERSWITCH_MERCHANT_CODE=your_merchant_code
INTERSWITCH_ELECTRICITY_PAYMENT_CODE=10902
INTERSWITCH_SCOPE=profile

# Demo fallback mode
INTERSWITCH_DEMO_MODE=true
ENABLE_DEBUG_ROUTES=false

# Python engine
PYTHON_ENGINE_URL=http://localhost:8001
